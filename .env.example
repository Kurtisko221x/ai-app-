# ── DATABÁZA (PostgreSQL) ─────────────────────────────────────────────
# Lokálne aj na Railway. URL získaš z Railway Postgres (viď DEPLOY.md).
# Formát: postgresql://user:heslo@host:port/databaza
DATABASE_URL="postgresql://user:password@localhost:5432/xskinny"

# ── OPENROUTER (AI model) ─────────────────────────────────────────────
# Získaš na https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PRIHLASOVANIE ─────────────────────────────────────────────────────
# Tajný kľúč na podpisovanie cookies. V PRODUKCII musí byť náhodný a tajný!
# Vygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=zmen-ma-na-nahodny-dlhy-retazec

# Emaily adminov (owner), oddelené čiarkou. Tieto účty majú prístup do /admin.
ADMIN_EMAILS=kurtegrell@gmail.com

# URL appky (na produkcii tvoja Railway doména, napr. https://xskinny.up.railway.app)
APP_URL=http://localhost:3000

# ── DISCORD (bot + prihlásenie cez Discord) ───────────────────────────
# Vytvor appku na https://discord.com/developers/applications (viď DISCORD.md)
# WEB služba potrebuje CLIENT_ID + CLIENT_SECRET (prihlásenie cez Discord):
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# BOT služba potrebuje TOKEN + CLIENT_ID (+ nepovinne GUILD_ID):
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Webhook do kanála #oznamy (Discord → Edit Channel → Integrations → Webhooks).
# Cez neho admin posiela novinky z webu priamo na Discord.
DISCORD_ANNOUNCE_WEBHOOK=
